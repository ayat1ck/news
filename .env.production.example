# Production env for Selectel / Linux server
# Copy to .env on the server and fill with real values.

# HTTP/HTTPS entrypoint for Caddy.
# For IP-only setup use: http://178.72.165.202
# For domain setup use: admin.example.ru
CADDY_SITE_ADDRESS=admin.example.ru

# App
APP_ENV=production
APP_DEBUG=false
SECRET_KEY=replace-with-a-long-random-secret
ALLOW_PUBLIC_REGISTRATION=false
SEED_DEMO_CONTENT=false

# Optional: bootstrap first admin on an empty database.
# Use real non-default values. If you leave them empty, bootstrap admin will not be created.
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_USERNAME=
BOOTSTRAP_ADMIN_PASSWORD=

# URLs
# For IP-only setup use http://178.72.165.202
# For domain setup use https://admin.example.ru
BACKEND_URL=https://admin.example.ru
PUBLIC_SITE_URL=https://admin.example.ru
CORS_ORIGINS=https://admin.example.ru

# PostgreSQL
POSTGRES_USER=news
POSTGRES_PASSWORD=replace-with-a-strong-postgres-password
POSTGRES_DB=news_platform

# AI
AI_PROVIDER=yandex
YANDEX_API_KEY=
YANDEX_FOLDER_ID=
YANDEX_TEXT_MODEL=gpt://<folder_id>/yandexgpt/latest
YANDEX_IMAGE_MODEL=art://<folder_id>/yandex-art/latest
ENABLE_AI_IMAGES=true

# Optional: if left empty, Telegram can be configured later from the admin panel.
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION_STRING=
TELEGRAM_BOT_TOKEN=
TELEGRAM_PUBLISH_CHANNEL_ID=

# Optional: if left empty, VK token can be configured later from the admin panel.
VK_ACCESS_TOKEN=

# Automation
AUTO_APPROVE_ENABLED=false
AUTO_PUBLISH_ENABLED=false
AUTO_PUBLISH_TARGETS=website,telegram
AUTO_PUBLISH_MAX_PER_RUN=0
