# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/news_platform
DATABASE_URL_SYNC=postgresql://postgres:postgres@postgres:5432/news_platform

# Redis
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Security
SECRET_KEY=change-me-to-a-random-secret-key-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ALLOW_PUBLIC_REGISTRATION=false
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=admin123
SEED_DEMO_CONTENT=true

# AI Providers
AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
OPENAI_API_KEY=
OPENROUTER_API_KEY=
GENERATE_IMAGE_FALLBACKS=true

# Telegram
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION_STRING=
TELEGRAM_BOT_TOKEN=
TELEGRAM_PUBLISH_CHANNEL_ID=

# Collection
COLLECTION_INTERVAL_MINUTES=60
AUTO_APPROVE_ENABLED=false
AUTO_PUBLISH_ENABLED=false
AUTO_PUBLISH_TARGETS=website,telegram

# App
APP_ENV=development
APP_DEBUG=true
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
BACKEND_URL=http://localhost:8000
PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_HOST=localhost
NEXT_PUBLIC_ADMIN_HOST=
NEXT_PUBLIC_API_URL=http://localhost:8000
